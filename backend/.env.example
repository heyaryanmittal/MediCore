# ============================================================
# MediCore Backend — Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your real .env file to version control.
# ============================================================


# ------------------------------------------------------------
# Database Configuration (Required)
# ------------------------------------------------------------
# Option A — MongoDB Atlas SRV URL (recommended for cloud):
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# Option B — Standard Atlas URL (use if ISP blocks SRV DNS):
#   MONGODB_URI=mongodb://<user>:<password>@<shard-00>.mongodb.net:27017,<shard-01>.mongodb.net:27017,<shard-02>.mongodb.net:27017/<dbname>?ssl=true&replicaSet=<replicaSet>&authSource=admin&retryWrites=true&w=majority
#
# Option C — Local MongoDB:
#   MONGODB_URI=mongodb://localhost:27017/medicore
MONGODB_URI=your_mongodb_connection_string_here


# ------------------------------------------------------------
# JWT Configuration (Required)
# ------------------------------------------------------------
# Use strong, randomly generated secrets (min 32 chars recommended)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d


# ------------------------------------------------------------
# Groq AI Configuration (Required for chatbot feature)
# ------------------------------------------------------------
# Get your API key from: https://console.groq.com
# BACKUP key is optional but recommended for high availability
GROQ_API_KEY_PRIMARY=your_groq_primary_api_key_here
GROQ_API_KEY_BACKUP=your_groq_backup_api_key_here


# ------------------------------------------------------------
# Email Configuration (Required for notifications)
# ------------------------------------------------------------
# For Gmail: enable 2FA and generate an App Password
# App Passwords: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here


# ------------------------------------------------------------
# Cloudinary Configuration (Required for file uploads)
# ------------------------------------------------------------
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name


# ------------------------------------------------------------
# Razorpay Configuration (Required for payment processing)
# ------------------------------------------------------------
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_...) during development
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here


# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
PORT=5000
NODE_ENV=development

# URL of your deployed frontend (used for CORS)
# e.g. https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
